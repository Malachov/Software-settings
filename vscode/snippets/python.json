{
  // Place your snippets for python here. Each snippet is defined under a snippet name and has a prefix, body and
  // description. The prefix is what is used to trigger the snippet and the body will be expanded and inserted. Possible variables are:
  // $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. Placeholders with the
  // same ids are connected.
  // Example:
  // "Print to console": {
  // 	"prefix": "log",
  // 	"body": [
  // 		"console.log('$1');",
  // 		"$2"
  // 	],
  // 	"description": "Log output to console"
  // }

  "If __name == '__main__'": {
    "prefix": "'If __name == '__main__':",
    "body": ["", "if __name__ == '__main__':", "    "],
    "description": "Insert logic to skip file if not main."
  },

  "from __future__ import annotations": {
    "prefix": "from __future__ import annotations",
    "body": ["from __future__ import annotations"],
    "description": "Insert library allowing type hints for older python versions."
  },

  "Print visible": {
    "prefix": "print_visible",
    "body": [
        "print(f\"\\n\\n\\n {$1} \\n\\n\\n\")"
        
    ]
},

"Check if installed": {
    "prefix": "check_if_installed",
    "body": [
        "try:"
        "    import numpy"
        "except  ModuleNotFoundError:"
        "    raise ModuleNotFoundError('$1')",

    ]
  }
}
